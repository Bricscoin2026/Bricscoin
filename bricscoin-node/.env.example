# BricsCoin Node Configuration
# Copy this file to .env and edit as needed

# Your node's public URL (REQUIRED for P2P — other nodes use this to reach you)
# Must be accessible from the internet (e.g. https://my-node.example.com)
# If not set, the node will sync but won't be discoverable by others
NODE_URL=

# Your node's unique identifier (leave empty for auto-generation)
NODE_ID=

# Primary seed node (default: main BricsCoin network)
SEED_NODE=https://bricscoin26.org

# Additional seed nodes (comma-separated)
SEED_NODES=

# MongoDB connection string
MONGO_URL=mongodb://mongo:27017/

# Database name (use a unique name per node)
DB_NAME=bricscoin_node

# API port
NODE_PORT=8333
