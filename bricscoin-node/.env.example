# BricsCoin Node Configuration
# Copy this file to .env and edit as needed

# Your node's unique identifier (leave empty for auto-generation)
NODE_ID=

# Your node's public URL (required for P2P networking)
# Example: https://my-bricscoin-node.com
NODE_URL=

# Seed nodes to connect to (comma-separated)
# Default connects to the main BricsCoin network
SEED_NODES=https://bricscoin26.org

# MongoDB connection string
MONGO_URL=mongodb://bricscoin-db:27017

# Database name
DB_NAME=bricscoin

# CORS origins (comma-separated, use * for all)
CORS_ORIGINS=*
