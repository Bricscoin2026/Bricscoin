{
  "name": "bricscoin-core",
  "version": "3.0.0",
  "description": "BricsCoin Core Desktop Wallet - Quantum-Safe",
  "main": "main.js",
  "homepage": "https://bricscoin26.org",
  "author": {
    "name": "Jabo86",
    "email": "info@bricscoin26.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/Bricscoin_26/Bricscoin.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:all": "electron-builder --linux --win --publish never"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "org.bricscoin.core",
    "productName": "BricsCoin Core",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "offline.html",
      "icon.png",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Finance",
      "maintainer": "info@bricscoin26.org"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.finance",
      "identity": null
    },
    "publish": null
  }
}
