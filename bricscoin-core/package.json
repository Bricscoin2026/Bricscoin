{
  "name": "bricscoin-core",
  "version": "3.0.0",
  "description": "BricsCoin Core Desktop Wallet with PQC Quantum-Safe Support",
  "main": "main.js",
  "homepage": "https://bricscoin26.org",
  "author": {
    "name": "Jabo86",
    "email": "info@bricscoin26.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/Bricscoin_26/Bricscoin.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "@noble/post-quantum": "0.5.4",
    "elliptic": "^6.5.4",
    "js-sha256": "^0.11.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "org.bricscoin.core",
    "productName": "BricsCoin Core",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,test,__tests__,tests,spec,*.ts}"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Finance",
      "maintainer": "info@bricscoin26.org"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.finance"
    },
    "publish": null
  }
}
